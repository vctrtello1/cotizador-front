  token: {{authToken}}
}

headers {
  Content-Type: application/json
  Accept: application/json
}

body:json {
  {
    "nombre": "Tira LED blanco frío",
    "descripcion": "LED 6000K, 120 LEDs/metro",
    "precio": 35.00
  }
}
